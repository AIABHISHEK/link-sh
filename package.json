{
  "name": "link-sh",
  "devDependencies": {
    "dotenv-expand": "^12.0.3",
    "node-pg-migrate": "^8.0.4"
  },
  "private": true,
  "scripts": {
    "dev:public-redirect": "bun run services/public-redirect/src/server.ts",
    "dev:dashboard-api": "bun run services/dashboard-api/src/server.ts",
    "dev:aggregation-worker": "bun run services/aggregation-worker/src/index.ts",
    "dev:redirect": "bun run dev:public-redirect",
    "dev:aggregator": "bun run dev:aggregation-worker",
    "migrate:create": "node-pg-migrate create",
    "migrate:up": "bun run services/dashboard-api/scripts/migrate.ts up",
    "migrate:down": "bun run services/dashboard-api/scripts/migrate.ts down"
  },
  "type": "module",
  "workspaces": [
    "services/*",
    "packages/*"
  ]
}
